# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=scheduler_db
POSTGRES_USER=scheduler
POSTGRES_PASSWORD=scheduler_pass

# ── Scheduler ──────────────────────────────────────────────────────────────────
SCHEDULER_TIMEZONE=America/Sao_Paulo
SCHEDULER_THREAD_POOL_SIZE=10

# ── Logging ────────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── API / Segurança ──────────────────────────────────────────────────────────────
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
# NUNCA use o valor padrão em produção!
JWT_SECRET_KEY=troque-por-uma-chave-segura-em-producao

# Senha do usuário admin criado automaticamente no primeiro start
# Altere via PUT /users/{id} após o primeiro login
ADMIN_DEFAULT_PASSWORD=admin123
